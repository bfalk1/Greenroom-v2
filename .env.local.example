# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Database (Supabase Postgres)
DATABASE_URL=
DIRECT_URL=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Stripe Price IDs (set after creating products in Stripe Dashboard)
STRIPE_GA_PRICE_ID=
STRIPE_VIP_PRICE_ID=
STRIPE_AA_PRICE_ID=
NEXT_PUBLIC_STRIPE_GA_PRICE_ID=
NEXT_PUBLIC_STRIPE_VIP_PRICE_ID=
NEXT_PUBLIC_STRIPE_AA_PRICE_ID=
NEXT_PUBLIC_STRIPE_CREDITS_50_PRICE_ID=
NEXT_PUBLIC_STRIPE_CREDITS_150_PRICE_ID=
NEXT_PUBLIC_STRIPE_CREDITS_400_PRICE_ID=

# Returning-subscriber VIP lifetime offer (password-gated /vip page).
# VIP_OFFER_PASSWORD: access code handed to past subscribers (defaults to GRVIP
#   if unset). Compared server-side only — never shipped to the client.
# STRIPE_VIP_LIFETIME_COUPON_ID: id of a Stripe coupon for $6.00 off
#   (amount_off=600, currency=usd, duration=forever). The lifetime VIP checkout
#   rides the normal VIP price + this coupon. If unset, the lifetime offer is
#   treated as unavailable rather than charging full price.
# VIP_OFFER_SECRET (optional): signs the unlock cookie so the gate can't be
#   bypassed by hand-setting the cookie. Falls back to STRIPE_SECRET_KEY when
#   unset; set a dedicated value to keep unlocks stable across key rotations.
VIP_OFFER_PASSWORD=GRVIP
STRIPE_VIP_LIFETIME_COUPON_ID=
VIP_OFFER_SECRET=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
# REQUIRED in every deployed environment. The payout cron routes now fail
# CLOSED — if CRON_SECRET is unset/empty they reject all requests (they move
# real money). Set the same value here and in the Vercel Cron Authorization header.
CRON_SECRET=

# Rate limiting (Vercel KV / Upstash). Provided automatically by the Vercel KV
# integration. When unset, the limiter falls back to a best-effort in-memory
# window (fine for local dev; provision KV for production protection).
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Resend (email)
RESEND_API_KEY=

# PostHog Analytics
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
