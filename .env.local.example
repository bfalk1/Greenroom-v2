# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Database (Supabase Postgres)
DATABASE_URL=
DIRECT_URL=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Stripe Price IDs (set after creating products in Stripe Dashboard)
STRIPE_GA_PRICE_ID=
STRIPE_VIP_PRICE_ID=
STRIPE_AA_PRICE_ID=
NEXT_PUBLIC_STRIPE_GA_PRICE_ID=
NEXT_PUBLIC_STRIPE_VIP_PRICE_ID=
NEXT_PUBLIC_STRIPE_AA_PRICE_ID=
NEXT_PUBLIC_STRIPE_CREDITS_50_PRICE_ID=
NEXT_PUBLIC_STRIPE_CREDITS_150_PRICE_ID=
NEXT_PUBLIC_STRIPE_CREDITS_400_PRICE_ID=

# PayPal (credit pack checkout). Optional — leave unset to disable PayPal
# entirely: the UI hides the button and the API routes return 503.
# All THREE server vars below are required before checkout enables — eCheck
# settlement and crash recovery depend on the signature-verified webhook, so
# register the webhook (subscribe to CHECKOUT.ORDER.APPROVED and the
# PAYMENT.CAPTURE.* events) before taking money.
# PAYPAL_ENV: "sandbox" (default) or "live".
PAYPAL_ENV=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
# Billing plan ids for subscriptions (create with scripts/create-paypal-plans.ts).
# Leave unset to offer PayPal for credit packs only.
PAYPAL_GA_PLAN_ID=
PAYPAL_VIP_PLAN_ID=
PAYPAL_AA_PLAN_ID=
# Set to "true" to show the PayPal button. NEXT_PUBLIC_* vars are inlined at
# build time — set it in the same deploy as the server vars above.
NEXT_PUBLIC_PAYPAL_ENABLED=
# Set to "true" to show PayPal subscribe buttons on /pricing — requires the
# PAYPAL_*_PLAN_ID vars above (packs-only configs leave this unset).
NEXT_PUBLIC_PAYPAL_SUBSCRIPTIONS_ENABLED=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
# REQUIRED in every deployed environment. The payout cron routes now fail
# CLOSED — if CRON_SECRET is unset/empty they reject all requests (they move
# real money). Set the same value here and in the Vercel Cron Authorization header.
CRON_SECRET=

# Rate limiting (Vercel KV / Upstash). Provided automatically by the Vercel KV
# integration. When unset, the limiter falls back to a best-effort in-memory
# window (fine for local dev; provision KV for production protection).
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Resend (email)
RESEND_API_KEY=

# PostHog Analytics
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
