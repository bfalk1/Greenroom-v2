// GREENROOM - Prisma Schema
// Next.js + Supabase (Postgres) + Stripe

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum UserRole {
  USER
  CREATOR
  MODERATOR
  ADMIN
}

enum CreditTransactionType {
  SUBSCRIPTION
  PURCHASE
  ADMIN_ADJUSTMENT
  UPGRADE_TOPUP
  REFUND
  REFERRAL
}

enum SampleType {
  LOOP
  ONE_SHOT
}

enum SampleStatus {
  DRAFT
  PUBLISHED
  REVIEW
  REMOVED // terminal moderator takedown: unpublished, hidden, creator cannot resurrect
}

enum ApplicationStatus {
  PENDING
  APPROVED
  DENIED
}

enum PayoutStatus {
  PENDING
  PAID
  FAILED
}

enum PresetCategory {
  BASS
  LEAD
  PAD
  PLUCK
  FX
  KEYS
  ARP
  SEQUENCE
  OTHER
}

enum SynthName {
  SERUM
  ASTRA
  SERUM_2
  PHASE_PLANT
  SPLICE
  VITAL
  SYLENTH1
  MASSIVE
  BEAT_MAKER
}

enum PresetStatus {
  DRAFT
  PUBLISHED
  REVIEW
  REMOVED // terminal moderator takedown: unpublished, hidden, creator cannot resurrect
}

// ─────────────────────────────────────────────
// USER & AUTH
// ─────────────────────────────────────────────

model User {
  id                 String    @id @default(uuid()) @db.Uuid
  email              String    @unique
  username           String?   @unique
  artistName         String?   @unique @map("artist_name")
  fullName           String?   @map("full_name")
  bio                String?
  avatarUrl          String?   @map("avatar_url")
  bannerUrl          String?   @map("banner_url")
  role               UserRole  @default(USER)
  socialLinks        Json?     @map("social_links") @db.JsonB
  addressLine1       String?   @map("address_line1")
  addressLine2       String?   @map("address_line2")
  city               String?
  state              String?
  postalCode         String?   @map("postal_code")
  country            String?
  subscriptionStatus String?   @map("subscription_status")
  profileCompleted   Boolean   @default(false) @map("profile_completed")
  stripeCustomerId   String?   @map("stripe_customer_id")
  payoutRate         Int?      @map("payout_rate") // DEPRECATED — unused. Per-creator rate lives in customPayoutRate (cents/credit).
  isActive           Boolean   @default(true) @map("is_active")
  isFlagged          Boolean   @default(false) @map("is_flagged")
  flagReason         String?   @map("flag_reason")
  flaggedAt          DateTime? @map("flagged_at")
  flaggedBy          String?   @map("flagged_by") @db.Uuid
  isWhitelisted      Boolean   @default(false) @map("is_whitelisted")
  customPayoutRate   Int?      @map("custom_payout_rate") // Per-creator payout rate in cents per credit (e.g., 7 = $0.07/credit). Null = platform default.
  termsAcceptedAt    DateTime? @map("terms_accepted_at")
  emailOptOutAt      DateTime? @map("email_opt_out_at") // Set when the user unsubscribes; suppresses marketing email (transactional still sends)
  referralCode       String?   @unique @map("referral_code") // Personal referral code, allocated lazily on first use of the referral panel
  vipOfferUnlockedAt DateTime? @map("vip_offer_unlocked_at") // Set when a creator referral grants this account the VIP lifetime discount; honored by checkout as an unlock (alongside the gr_vip_offer cookie). Permanent, never-paid eligibility still applies.
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  // Relations
  subscription         Subscription?
  creditBalance        CreditBalance?
  creditTransactions   CreditTransaction[]
  samples              Sample[]             @relation("CreatorSamples")
  presets              Preset[]             @relation("CreatorPresets")
  purchases            Purchase[]
  downloads            Download[]
  ratings              Rating[]
  favorites            Favorite[]
  following            Follow[]             @relation("Follower")
  followers            Follow[]             @relation("Creator")
  creatorApplication   CreatorApplication?  @relation("Applicant")
  reviewedApplications CreatorApplication[] @relation("Reviewer")
  payouts              CreatorPayout[]
  auditLogs            AuditLog[]
  sentInvites          CreatorInvite[]      @relation("InvitedBy")
  usedInvite           CreatorInvite?       @relation("InviteUsedBy")
  betaInvitesSent      BetaInvite[]         @relation("BetaInvitedBy")
  betaInviteUsed       BetaInvite?          @relation("BetaInviteUsedBy")
  paypalOrders         PaypalOrder[]
  referralsMade        Referral[]           @relation("Referrer")
  referralUsed         Referral?            @relation("ReferredUser")

  @@map("users")
}

// ─────────────────────────────────────────────
// SUBSCRIPTIONS & CREDITS
// ─────────────────────────────────────────────

model SubscriptionTier {
  id              String  @id @default(uuid()) @db.Uuid
  name            String  @unique // GA, VIP, AA
  displayName     String  @map("display_name") // General Admission, VIP, All Access
  creditsPerMonth Int     @map("credits_per_month")
  priceUsdCents   Int     @map("price_usd_cents")
  stripePriceId   String? @map("stripe_price_id")
  isActive        Boolean @default(true) @map("is_active")

  subscriptions Subscription[]

  @@map("subscription_tiers")
}

model Subscription {
  id                   String   @id @default(uuid()) @db.Uuid
  userId               String   @unique @map("user_id") @db.Uuid
  tierId               String   @map("tier_id") @db.Uuid
  provider             String   @default("stripe") // stripe | paypal
  stripeSubscriptionId String?  @map("stripe_subscription_id")
  paypalSubscriptionId String?  @unique @map("paypal_subscription_id")
  // Which funnel produced this subscription (e.g. "vip-lifetime"). Written at
  // activation so revenue can be attributed to an offer — provider objects
  // alone can't tell a lifetime sub from a full-price one once coupons change.
  acquisitionSource    String?  @map("acquisition_source")
  currentPeriodStart   DateTime @map("current_period_start")
  currentPeriodEnd     DateTime @map("current_period_end")
  cancelAtPeriodEnd    Boolean  @default(false) @map("cancel_at_period_end")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  user User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  tier SubscriptionTier @relation(fields: [tierId], references: [id])

  @@map("subscriptions")
}

model CreditBalance {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @unique @map("user_id") @db.Uuid
  balance   Int      @default(0)
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("credit_balances")
}

model CreditTransaction {
  id          String                @id @default(uuid()) @db.Uuid
  userId      String                @map("user_id") @db.Uuid
  amount      Int // positive = credit, negative = debit
  type        CreditTransactionType
  referenceId String?               @map("reference_id")
  note        String?
  createdAt   DateTime              @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([createdAt])
  @@map("credit_transactions")
}

// ─────────────────────────────────────────────
// SAMPLES & CATALOG
// ─────────────────────────────────────────────

model Sample {
  id             String       @id @default(uuid()) @db.Uuid
  creatorId      String       @map("creator_id") @db.Uuid
  name           String
  slug           String       @unique
  fileUrl        String       @map("file_url")
  previewUrl     String?      @map("preview_url")
  coverImageUrl  String?      @map("cover_image_url")
  waveformData   Json?        @map("waveform_data") @db.JsonB // Array of amplitude values for waveform display
  sampleType     SampleType   @map("sample_type")
  genre          String
  instrumentType String       @map("instrument_type")
  key            String?
  bpm            Int?
  creditPrice    Int          @default(1) @map("credit_price")
  durationMs     Int?         @map("duration_ms")
  fileSizeBytes  BigInt?      @map("file_size_bytes")
  tags           String[]     @default([])
  downloadCount  Int          @default(0) @map("download_count")
  ratingAvg      Float        @default(0) @map("rating_avg")
  ratingCount    Int          @default(0) @map("rating_count")
  isActive       Boolean      @default(true) @map("is_active")
  status         SampleStatus @default(DRAFT)
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  creator   User       @relation("CreatorSamples", fields: [creatorId], references: [id])
  purchases Purchase[]
  downloads Download[]
  ratings   Rating[]
  favorites Favorite[]

  @@index([genre])
  @@index([instrumentType])
  @@index([sampleType])
  @@index([key])
  @@index([bpm])
  @@index([status])
  @@index([downloadCount(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@index([creatorId])
  @@map("samples")
}

// ─────────────────────────────────────────────
// PRESETS & SYNTH CATALOG
// ─────────────────────────────────────────────

model Preset {
  id                 String         @id @default(uuid()) @db.Uuid
  creatorId          String         @map("creator_id") @db.Uuid
  name               String
  slug               String         @unique
  description        String?
  synthName          SynthName      @map("synth_name")
  presetCategory     PresetCategory @map("preset_category")
  genre              String
  tags               String[]       @default([])
  creditPrice        Int            @default(1) @map("credit_price")
  fileUrl            String         @map("file_url")
  previewUrl         String?        @map("preview_url")
  coverImageUrl      String?        @map("cover_image_url")
  fileSizeBytes      BigInt?        @map("file_size_bytes")
  compatibleVersions String[]       @default([]) @map("compatible_versions")
  parameterSnapshot  Json?          @map("parameter_snapshot") @db.JsonB
  modulationInfo     Json?          @map("modulation_info") @db.JsonB
  macroDescriptions  Json?          @map("macro_descriptions") @db.JsonB
  isInitPreset       Boolean        @default(false) @map("is_init_preset")
  downloadCount      Int            @default(0) @map("download_count")
  ratingAvg          Float          @default(0) @map("rating_avg")
  ratingCount        Int            @default(0) @map("rating_count")
  isActive           Boolean        @default(true) @map("is_active")
  status             PresetStatus   @default(DRAFT)
  createdAt          DateTime       @default(now()) @map("created_at")
  updatedAt          DateTime       @updatedAt @map("updated_at")

  creator   User       @relation("CreatorPresets", fields: [creatorId], references: [id])
  purchases Purchase[]
  downloads Download[]
  ratings   Rating[]
  favorites Favorite[]

  @@index([synthName])
  @@index([presetCategory])
  @@index([genre])
  @@index([status])
  @@index([downloadCount(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@index([creatorId])
  @@map("presets")
}

// ─────────────────────────────────────────────
// PURCHASES, DOWNLOADS & ENGAGEMENT
// ─────────────────────────────────────────────

model Purchase {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  sampleId     String?  @map("sample_id") @db.Uuid
  presetId     String?  @map("preset_id") @db.Uuid
  creditsSpent Int      @map("credits_spent")
  createdAt    DateTime @default(now()) @map("created_at")

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  sample    Sample?    @relation(fields: [sampleId], references: [id])
  preset    Preset?    @relation(fields: [presetId], references: [id])
  downloads Download[]

  @@unique([userId, sampleId])
  @@unique([userId, presetId])
  @@index([userId])
  @@index([sampleId])
  @@index([presetId])
  @@index([createdAt])
  @@map("purchases")
}

model Download {
  id         String   @id @default(uuid()) @db.Uuid
  purchaseId String   @map("purchase_id") @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  sampleId   String?  @map("sample_id") @db.Uuid
  presetId   String?  @map("preset_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at")

  purchase Purchase @relation(fields: [purchaseId], references: [id])
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sample   Sample?  @relation(fields: [sampleId], references: [id])
  preset   Preset?  @relation(fields: [presetId], references: [id])

  @@index([userId])
  @@index([sampleId])
  @@index([presetId])
  @@index([createdAt])
  @@map("downloads")
}

model Rating {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  sampleId  String?  @map("sample_id") @db.Uuid
  presetId  String?  @map("preset_id") @db.Uuid
  score     Int // 1-5
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  sample Sample? @relation(fields: [sampleId], references: [id])
  preset Preset? @relation(fields: [presetId], references: [id])

  @@unique([userId, sampleId])
  @@unique([userId, presetId])
  @@map("ratings")
}

model Favorite {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  sampleId  String?  @map("sample_id") @db.Uuid
  presetId  String?  @map("preset_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  sample Sample? @relation(fields: [sampleId], references: [id])
  preset Preset? @relation(fields: [presetId], references: [id])

  @@unique([userId, sampleId])
  @@unique([userId, presetId])
  @@index([userId])
  @@map("favorites")
}

model Follow {
  id         String   @id @default(uuid()) @db.Uuid
  followerId String   @map("follower_id") @db.Uuid
  creatorId  String   @map("creator_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at")

  follower User @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  creator  User @relation("Creator", fields: [creatorId], references: [id], onDelete: Cascade)

  @@unique([followerId, creatorId])
  @@index([creatorId])
  @@map("follows")
}

// ─────────────────────────────────────────────
// CREATOR APPLICATION & PAYOUTS
// ─────────────────────────────────────────────

model CreatorInvite {
  id           String    @id @default(uuid()) @db.Uuid
  email        String    @unique
  artistName   String    @map("artist_name")
  message      String? // Optional personal message from admin
  invitedBy    String    @map("invited_by") @db.Uuid
  token        String    @unique @default(uuid()) @db.Uuid
  expiresAt    DateTime  @map("expires_at")
  usedAt       DateTime? @map("used_at")
  usedByUserId String?   @unique @map("used_by_user_id") @db.Uuid
  emailStatus  String    @default("pending") @map("email_status") // pending, sent, failed
  emailError   String?   @map("email_error")
  emailSentAt  DateTime? @map("email_sent_at")
  retryCount   Int       @default(0) @map("retry_count")
  createdAt    DateTime  @default(now()) @map("created_at")

  inviter User  @relation("InvitedBy", fields: [invitedBy], references: [id])
  usedBy  User? @relation("InviteUsedBy", fields: [usedByUserId], references: [id])

  @@map("creator_invites")
}

model BetaInvite {
  id           String    @id @default(uuid()) @db.Uuid
  email        String    @unique
  message      String?
  invitedBy    String    @map("invited_by") @db.Uuid
  token        String    @unique @default(uuid()) @db.Uuid
  expiresAt    DateTime  @map("expires_at")
  usedAt       DateTime? @map("used_at")
  usedByUserId String?   @unique @map("used_by_user_id") @db.Uuid
  emailStatus  String    @default("pending") @map("email_status")
  emailError   String?   @map("email_error")
  emailSentAt  DateTime? @map("email_sent_at")
  retryCount   Int       @default(0) @map("retry_count")
  credits      Int       @default(100)
  createdAt    DateTime  @default(now()) @map("created_at")

  inviter User  @relation("BetaInvitedBy", fields: [invitedBy], references: [id])
  usedBy  User? @relation("BetaInviteUsedBy", fields: [usedByUserId], references: [id])

  @@map("beta_invites")
}

model CreatorApplication {
  id           String            @id @default(uuid()) @db.Uuid
  userId       String            @unique @map("user_id") @db.Uuid
  artistName   String            @map("artist_name")
  bio          String?
  socialLinks  Json?             @map("social_links") @db.JsonB
  sampleZipUrl String            @map("sample_zip_url")
  status       ApplicationStatus @default(PENDING)
  reviewedBy   String?           @map("reviewed_by") @db.Uuid
  reviewNote   String?           @map("review_note")
  termsAcceptedAt DateTime?      @map("terms_accepted_at")
  createdAt    DateTime          @default(now()) @map("created_at")
  reviewedAt   DateTime?         @map("reviewed_at")

  user     User  @relation("Applicant", fields: [userId], references: [id], onDelete: Cascade)
  reviewer User? @relation("Reviewer", fields: [reviewedBy], references: [id])

  @@map("creator_applications")
}

model CreatorPayout {
  id                String       @id @default(uuid()) @db.Uuid
  creatorId         String       @map("creator_id") @db.Uuid
  periodStart       DateTime     @map("period_start") @db.Date
  periodEnd         DateTime     @map("period_end") @db.Date
  totalCreditsSpent Int          @map("total_credits_spent")
  // GROSS earnings — this is what's deducted from the creator's unpaid balance.
  // The amount actually sent is amountUsdCents − processingFeeCents (net).
  amountUsdCents    Int          @map("amount_usd_cents")
  // Portion of amountUsdCents that is referral cash rewards (not catalog
  // sales), locked in at creation so the invoice can itemize it.
  referralBonusCents Int         @default(0) @map("referral_bonus_cents")
  // Payment processing fee (covered by the creator), locked in at request time.
  processingFeeCents Int         @default(0) @map("processing_fee_cents")
  // Invoice number assigned when the payout is created (from payout_invoice_seq).
  invoiceNumber     String?      @unique @map("invoice_number")
  status            PayoutStatus @default(PENDING)
  paidAt            DateTime?    @map("paid_at")
  // Optional proof-of-payment uploaded by an admin, stored in the private
  // payout-receipts bucket; visible to the creator via a signed URL.
  receiptPath       String?      @map("receipt_path")
  receiptUploadedAt DateTime?    @map("receipt_uploaded_at")
  createdAt         DateTime     @default(now()) @map("created_at")

  creator User @relation(fields: [creatorId], references: [id])

  @@unique([creatorId, periodStart, periodEnd])
  @@index([creatorId])
  @@index([periodStart, periodEnd])
  @@map("creator_payouts")
}

// ─────────────────────────────────────────────
// REFERRALS
// ─────────────────────────────────────────────

// One row per successful referral, created when the referred account is first
// created with a verified email. The unique referredUserId is the exactly-once
// guard: the two user-creation paths (/callback and /api/user/me) can race to
// redeem for the same brand-new account, and only one insert wins. Reward
// amounts are locked onto the row at redemption time — a CREATOR referrer's
// cash reward is priced at their effective payout rate that day, so later rate
// changes never alter what was granted. referrerCashCents feeds the payout
// system's unpaid-balance math via getCreatorReferralCashCents (src/lib/payouts.ts).
model Referral {
  id                String   @id @default(uuid()) @db.Uuid
  referrerId        String   @map("referrer_id") @db.Uuid
  // Nullable + SetNull: this row is an earnings record (referrerCashCents feeds
  // the payout math) and must outlive the referred account, so deleting the
  // referred user can't claw already-earned cash out of future catalog sales.
  // Postgres treats NULLs as distinct, so @unique still guards live redemptions.
  referredUserId    String?  @unique @map("referred_user_id") @db.Uuid
  // Credits granted to the referred (new) user.
  referredCredits   Int      @default(0) @map("referred_credits")
  // Credits granted to a USER (non-creator) referrer.
  referrerCredits   Int      @default(0) @map("referrer_credits")
  // Payout cash granted to a CREATOR referrer, in integer USD cents.
  referrerCashCents Int      @default(0) @map("referrer_cash_cents")
  // True when this is a creator referral — the referred user was granted the
  // VIP lifetime unlock at signup (snapshots the referrer-was-a-creator decision
  // so the reward type matches what the signup banner promised).
  referredVipOffer  Boolean  @default(false) @map("referred_vip_offer")
  // Rewards are earned only when the referred user activates a VIP subscription
  // (within REFERRAL_REWARD_WINDOW_DAYS of signup). Null until that resolves;
  // the amount fields above stay 0 while pending. Set once, terminally — the
  // exactly-once guard for the reward grant across activation paths/retries.
  rewardedAt        DateTime? @map("rewarded_at")
  // Set when the reward was withheld ("expired" — VIP activation too late or
  // never; "monthly_cap" — referrer over the cap, referred credits still granted).
  referrerRewardSkippedReason String? @map("referrer_reward_skipped_reason")
  createdAt         DateTime @default(now()) @map("created_at")

  referrer User  @relation("Referrer", fields: [referrerId], references: [id], onDelete: Cascade)
  referred User? @relation("ReferredUser", fields: [referredUserId], references: [id], onDelete: SetNull)

  @@index([referrerId, createdAt])
  @@map("referrals")
}

// ─────────────────────────────────────────────
// AUDIT LOG
// ─────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  actorId    String   @map("actor_id") @db.Uuid
  action     String // e.g. SAMPLE_DELETED, CREATOR_APPROVED, CREDIT_ADJUSTED
  targetType String   @map("target_type") // e.g. Sample, User, CreatorApplication
  targetId   String   @map("target_id") @db.Uuid
  metadata   Json?    @db.JsonB
  createdAt  DateTime @default(now()) @map("created_at")

  actor User @relation(fields: [actorId], references: [id])

  @@index([actorId])
  @@index([targetType, targetId])
  @@index([createdAt(sort: Desc)])
  @@map("audit_logs")
}

// ─────────────────────────────────────────────
// STRIPE WEBHOOK IDEMPOTENCY
// ─────────────────────────────────────────────

// One row per processed Stripe event id. Inserted inside the same transaction
// that grants credits, so a redelivered event hits the primary-key conflict and
// the grant rolls back — guaranteeing each event is processed exactly once.
model StripeWebhookEvent {
  id        String   @id // Stripe event id (evt_...)
  type      String
  createdAt DateTime @default(now()) @map("created_at")

  @@map("stripe_webhook_events")
}

// ─────────────────────────────────────────────
// PAYPAL ORDERS (one-time credit pack checkout)
// ─────────────────────────────────────────────

// PayPal analog of StripeWebhookEvent, used for SUBSCRIPTION credit grants:
// one row per idempotency marker (e.g. "sale:<txnId>" for a billing cycle's
// grant, "event:<eventId>" for upgrade top-ups), inserted inside the same
// transaction as the grant so a redelivered event conflicts and rolls back.
// (One-time credit packs use the paypal_orders status guard instead.)
model PaypalWebhookEvent {
  id        String   @id
  type      String
  createdAt DateTime @default(now()) @map("created_at")

  @@map("paypal_webhook_events")
}

// One row per PayPal checkout attempt, created before redirecting the user to
// PayPal. Credits are granted in the same transaction that flips status from
// CREATED to COMPLETED — the status guard makes the grant apply exactly once
// even when the return redirect and the webhook both try to settle the order.
model PaypalOrder {
  id             String   @id // PayPal order id
  userId         String   @map("user_id") @db.Uuid
  credits        Int
  amountUsdCents Int      @map("amount_usd_cents")
  status         String   @default("CREATED") // CREATED | COMPLETED | REFUNDED | DENIED
  captureId      String?  @map("capture_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([captureId])
  @@map("paypal_orders")
}

// ─────────────────────────────────────────────
// PLATFORM SETTINGS
// ─────────────────────────────────────────────

model PlatformSetting {
  id                String   @id @default("default")
  // Platform default creator payout rate in cents per credit (e.g., 7 = $0.07/credit)
  creatorPayoutRate Int      @default(7) @map("creator_payout_rate")
  // Credit value in USD cents (e.g., 10 = $0.10 per credit). Informational; no longer part of payout math.
  creditValueCents  Int      @default(10) @map("credit_value_cents")
  // Payout processing fee, covered by the creator: a percent part in basis
  // points (290 = 2.90%) plus a fixed part in cents (30 = $0.30).
  payoutFeeBps        Int    @default(290) @map("payout_fee_bps")
  payoutFeeFixedCents Int    @default(30) @map("payout_fee_fixed_cents")
  // Moderator whitelist (stored as JSON array of user IDs)
  moderatorIds      String[] @default([]) @map("moderator_ids") @db.Uuid
  updatedAt         DateTime @updatedAt @map("updated_at")
  updatedBy         String?  @map("updated_by") @db.Uuid

  @@map("platform_settings")
}

// ─────────────────────────────────────────────
// GENRES
// ─────────────────────────────────────────────

model Genre {
  id             String   @id @default(uuid()) @db.Uuid
  name           String   @unique // Displayed name
  normalizedName String   @unique @map("normalized_name") // Lowercase, no spaces
  isCustom       Boolean  @default(true) @map("is_custom")
  usageCount     Int      @default(0) @map("usage_count")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  createdBy      String?  @map("created_by") @db.Uuid

  @@index([normalizedName])
  @@index([usageCount(sort: Desc)])
  @@map("genres")
}

// ─────────────────────────────────────────────
// INSTRUMENT TYPES
// ─────────────────────────────────────────────

model InstrumentType {
  id             String   @id @default(uuid()) @db.Uuid
  name           String   @unique
  normalizedName String   @unique @map("normalized_name")
  category       String? // e.g., "Drums", "Synths", "Bass", "Vocals", etc.
  usageCount     Int      @default(0) @map("usage_count")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([category])
  @@index([usageCount(sort: Desc)])
  @@map("instrument_types")
}

// ─────────────────────────────────────────────
// WAITLIST
// ─────────────────────────────────────────────

model WaitlistEntry {
  id        String   @id @default(uuid()) @db.Uuid
  email     String   @unique
  source    String? // Optional: track where signup came from
  createdAt DateTime @default(now()) @map("created_at")

  @@map("waitlist_entries")
}
